---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  let tools = [];
  try {
    const data = await fetch(new URL('../../../data/tools.json', import.meta.url));
    const json = await data.json();
    tools = json.tools || [];
  } catch (e) {
    tools = [];
  }
  
  return tools.map(tool => ({
    params: { id: tool.id },
    props: { tool }
  }));
}

const { tool } = Astro.props;

if (!tool) {
  return Astro.redirect('/404');
}

const prosConsSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.name,
  "description": tool.description,
  "applicationCategory": tool.schema?.applicationCategory || "AIApplication",
  "operatingSystem": tool.schema?.operatingSystem || "Web",
  "offers": tool.schema?.offers || { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "aggregateRating": tool.schema?.aggregateRating || { "@type": "AggregateRating", "ratingValue": "4.5", "ratingCount": "1000" },
  "featureList": tool.features?.join(", "),
  "screenshot": tool.screenshot,
  "url": tool.url
};
---

<Layout 
  title={`${tool.name} ${tool.icon} | ZakiHub`}
  description={tool.description}
  image={tool.screenshot}
  type="product"
>
  <script type="application/ld+json" set:html={JSON.stringify(prosConsSchema)} />
  
  <div style="max-width: 900px; margin: 0 auto;">
    <!-- Breadcrumb -->
    <nav style="margin-bottom: 2rem; opacity: 0.6; font-size: 0.9rem;">
      <a href="/" style="color: inherit; text-decoration: none;">الرئيسية</a>
      <span style="margin: 0 0.5rem;">/</span>
      <a href="/tools/" style="color: inherit; text-decoration: none;">الأدوات</a>
      <span style="margin: 0 0.5rem;">/</span>
      <span style="color: var(--neon-green);">{tool.name}</span>
    </nav>

    <!-- Tool Header -->
    <div class="glass" style="padding: 2.5rem; border-radius: 32px; margin-bottom: 2rem; text-align: center; position: relative; overflow: hidden;">
      <div style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(0,255,136,0.05) 0%, transparent 70%); pointer-events: none;"></div>
      
      <div style="font-size: 5rem; margin-bottom: 1rem; display: block;">{tool.icon}</div>
      <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{tool.name}</h1>
      <span class="tool-category" style="display: inline-block; padding: 0.25rem 1rem; border-radius: 20px; background: rgba(0,255,136,0.1); color: var(--neon-green); font-size: 0.9rem; font-weight: 600;">
        {tool.category}
      </span>
      
      <div style="display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap;">
        <div style="text-align: center;">
          <div style="font-size: 1.8rem; font-weight: 800; color: var(--neon-gold);">⭐ {tool.rating}</div>
          <div style="font-size: 0.8rem; opacity: 0.6;">التقييم</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 1.8rem; font-weight: 800; color: var(--neon-cyan);">{tool.users}</div>
          <div style="font-size: 0.8rem; opacity: 0.6;">مستخدم</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 1.8rem; font-weight: 800; color: var(--neon-pink);">
            {tool.pricing === 'Free' ? 'مجاني' : tool.pricing === 'Freemium' ? 'مجاني/مدفوع' : 'مدفوع'}
          </div>
          <div style="font-size: 0.8rem; opacity: 0.6;">السعر</div>
        </div>
      </div>
    </div>

    <!-- Description -->
    <div class="glass" style="padding: 2rem; border-radius: 24px; margin-bottom: 2rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">📝 الوصف</h2>
      <p style="font-size: 1.1rem; line-height: 1.8; opacity: 0.9;">{tool.description}</p>
      
      <div style="margin-top: 1.5rem;">
        <h3 style="font-size: 1rem; margin-bottom: 0.75rem; opacity: 0.8;">🏷️ الوسوم</h3>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          {tool.tags?.map(tag => (
            <span style="padding: 0.35rem 0.9rem; border-radius: 20px; background: var(--bg-glass); border: 1px solid var(--border-glass); font-size: 0.85rem;">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Features -->
    <div class="glass" style="padding: 2rem; border-radius: 24px; margin-bottom: 2rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1rem;">✨ المميزات</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        {tool.features?.map(feature => (
          <div style="display: flex; align-items: center; gap: 0.75rem; padding: 1rem; background: rgba(0,255,136,0.05); border-radius: 16px; border: 1px solid rgba(0,255,136,0.1);">
            <span style="font-size: 1.2rem;">✅</span>
            <span>{feature}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Pros & Cons -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
      <div class="glass" style="padding: 2rem; border-radius: 24px; border-top: 3px solid var(--neon-green);">
        <h3 style="color: var(--neon-green); margin-bottom: 1rem; font-size: 1.2rem;">👍 الإيجابيات</h3>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
          {tool.pros?.map(pro => (
            <li style="display: flex; align-items: center; gap: 0.5rem;">
              <span style="color: var(--neon-green);">▸</span>
              {pro}
            </li>
          ))}
        </ul>
      </div>
      
      <div class="glass" style="padding: 2rem; border-radius: 24px; border-top: 3px solid var(--neon-pink);">
        <h3 style="color: var(--neon-pink); margin-bottom: 1rem; font-size: 1.2rem;">👎 السلبيات</h3>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
          {tool.cons?.map(con => (
            <li style="display: flex; align-items: center; gap: 0.5rem;">
              <span style="color: var(--neon-pink);">▸</span>
              {con}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div style="text-align: center; padding: 3rem; background: var(--bg-glass); border-radius: 32px; border: 1px solid var(--border-glow);">
      <h2 style="margin-bottom: 1.5rem;">جاهز تجرب {tool.name}؟</h2>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a 
          href={tool.url} 
          target="_blank" 
          rel="noopener" 
          class="btn-primary" 
          style="font-size: 1.2rem; padding: 1rem 2.5rem;"
          onclick="if(window.dopamine) { window.dopamine.discoverTool('{tool.id}'); window.dopamine.addPoints(15, 'زيارة رسمية'); }"
        >
          <span>🚀</span>
          جرب {tool.name} الآن
        </a>
        <button 
          class="btn-secondary" 
          style="font-size: 1.2rem; padding: 1rem 2.5rem;"
          onclick="if(window.dopamine) { window.dopamine.addPoints(5, 'مشاركة'); window.dopamine.showToast('🔗 تم نسخ الرابط!', 'success'); navigator.clipboard.writeText(window.location.href); }"
        >
          <span>📤</span>
          مشاركة
        </button>
      </div>
    </div>

    <!-- Related Tools -->
    <div style="margin-top: 3rem;">
      <h2 style="font-size: 1.5rem; margin-bottom: 1.5rem;">🛠️ أدوات مشابهة</h2>
      <div class="tools-grid">
        {/* هنا يمكن إضافة أدوات من نفس الفئة */}
      </div>
    </div>
  </div>
</Layout>
